# Check if the environment variables are loaded correctly
CHECK=ok

# Environment type
ENVIRONMENT=dev

# DB
DB_TITLE=DB
DB_DESCRIPTION=Database
DB_IS_ACTIVE=true
DB_HOST=db
DB_PORT=5432
DB_NAME=db
DB_USER=postgres
DB_PASSWORD=Dbpass123
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=10

# Email sender
EMAIL_USERNAME=[YOUR_EMAIL_USERNAME]
EMAIL_PASSWORD=[YOUR_EMAIL_PASSWORD]
EMAIL_FROM=[YOUR_EMAIL_FROM]
EMAIL_FROM_NAME=[YOUR_EMAIL_FROM_NAME]
EMAIL_SERVER=[YOUR_EMAIL_SERVER]
EMAIL_PORT=[YOUR_EMAIL_PORT]
EMAIL_STARTTLS=[YOUR_EMAIL_STARTTLS]
EMAIL_SSL_TLS=[YOUR_EMAIL_SSL_TLS]
EMAIL_USE_CREDENTIALS=[YOUR_EMAIL_USE_CREDENTIALS]
EMAIL_VALIDATE_CERTS=[YOUR_EMAIL_VALIDATE_CERTS]

# JWT user auth
USER_AUTH_JWT_SECRET_KEY=J6ceGyKg7ZNKFh1MVpKu8qMMNhqOhegFSh7tWkbErew=
USER_AUTH_JWT_ALGORITHM_TYPE=HS256
USER_AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=1500
USER_AUTH_SESSION_EXPIRE_DAYS=15

# Error report email config
ERROR_REPORT_EMAIL_ADDRESS=[YOUR_ERROR_REPORT_EMAIL_ADDRESS]
ERROR_EMAIL_REPORT_ENABLED=True

# File Storage
# Root user
FILE_STORAGE_ROOT_USER_LOGIN=admin
FILE_STORAGE_ROOT_USER_PASSWORD=FilestoragePass123
# Backend connection
FILE_STORAGE_CLIENT_LOGIN=admin
FILE_STORAGE_CLIENT_PASSWORD=FilestoragePass123
FILE_STORAGE_HOST=file-storage
FILE_STORAGE_PORT=9000
FILE_STORAGE_USE_SSL=false

# Image Cropper
IMAGE_CROPPER_DEFAULT_MAX_WIDTH=1024
IMAGE_CROPPER_DEFAULT_MAX_HEIGHT=1024
IMAGE_CROPPER_DEFAULT_QUALITY=82
IMAGE_CROPPER_DEFAULT_OUTPUT_FORMAT=webp
IMAGE_CROPPER_ALLOW_UPSCALE=false
